<div class="cont_wrap" id="<%= dom_id client %>">
  <div class="menu_list">
    <strong>顧客名:</strong>
    <%= client.name %>
  </div>

  <div class="menu_list">
    <strong>担当者名:</strong>
    <%= client.manager_name %>
  </div>

  <div class="menu_list">
    <strong>メールアドレス:</strong>
    <%= client.email %>
  </div>

  <div class="menu_list">
    <strong>所在地:</strong>
    <%= client.address %>
  </div>

  <div class="menu_list">
    <strong>登録者:</strong>
    <%= client.user_id %>
  </div>

</div>
