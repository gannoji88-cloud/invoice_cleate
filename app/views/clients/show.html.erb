<div id="all_wrap">
<div id="wrapper">

<div class="title">■□ 顧客の詳細 □■</div>

<%= render @client %>

<div class="middle_title">
  <%= link_to "この顧客を変更する", edit_client_path(@client) %> |
  <%= link_to "顧客一覧に戻る", clients_path %>

  <%= button_to "顧客データを消去", @client, method: :delete, data: { confirm: "本当に消去しますか？"} , class:"btn_a" %>
</div>

<div class="menu">
<div class="menu_list">● MENU</div>
<div class="menu_list"><%= link_to "ダッシュボード", dashboard_path, class: "btn" %></div>
