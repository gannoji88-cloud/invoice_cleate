<%= form_with(model: item) do |form| %>
  <% if item.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

      <ul>
        <% item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div id="input_space" class="field">
    <%= form.label :name, "● 商品・サービス名" ,style: "display: block", class:"middle_title" %>
    <%= form.text_field :name %>
  </div>

  <div id="input_space" class="field">
    <%= form.label :unit_price, "● 単価(円))" ,style: "display: block", class:"middle_title" %>
    <%= form.number_field :unit_price %>
  </div>

  <div id="input_space" class="field">
    <%= form.label :user_id, "● 登録者", style: "display: block", class:"middle_title" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.submit "登録する", class:"btn_a" %>
  </div>
<% end %>
