<div id="all_wrap">
<div id="wrapper">
<div class="title">■□ 請求書一覧／ダッシュボード □■</div>

<p class="middle_title">ようこそ、<%= current_user.email %> さん</p>

<div>
<%= link_to "＋ 新しい請求書を作る", new_sales_order_path, class: "btn_a" %>
</div>

<div class="middle_title">■ 最近の請求書一覧</div>
<% if @recent_sales.any? %>
<table style="width: 100%; margin-top: 10px; border-collapse: collapse; font-size: 18px;">
    <thead>
    <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
        <th style="padding: 10px; text-align: left;">日付</th>
        <th style="padding: 10px; text-align: left;">顧客名</th>
        <th style="padding: 10px; text-align: right;">金額</th>
    </tr>
    </thead>
    <tbody>
    <% @recent_sales.each do |sale| %>
        <tr style="border-bottom: 1px solid #eee;">
        <td style="padding: 10px;"><%= sale.order_date.strftime('%Y/%m/%d') %></td>
        <td style="padding: 10px;"><%= sale.client.name %></td>
        <td style="padding: 10px; text-align: right;"><%= number_to_currency(sale.total_amount, unit: "￥", precision: 0) %></td>
        </tr>
    <% end %>
    </tbody>
</table>
<% else %>
<p style="margin-top: 10px; color: #666;">まだ登録された売上データはありません。</p>
<% end %>

<div class="menu">
<div class="menu_list">● MENU</div>
<div class="menu_list"><%= link_to "顧客一覧・登録", clients_path, class: "btn" %></div>
<div class="menu_list"><%= link_to "商品一覧・登録", items_path, class: "btn" %></div>
<div class="menu_list"><%= link_to "売上伝票入力", new_sales_order_path, class: "btn" %></div>
<div class="menu_list"><%= link_to "売上履歴一覧", sales_orders_path, class: "btn" %></div>
</div><!-- menu -->

</div><!-- wrapper -->
</div><!-- all_wrap -->