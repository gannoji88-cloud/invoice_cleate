
<div id="all_wrap">
<div id="wrapper">
<div class="title">■□ 請求書自動作成システム LOGIN □■</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

<div id="login_mail_title">● メールアドレス</div>
<div id="login_mail_input">
<%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "xxxx@example.com" %>
</div>

<div id="login_pass_title">● パスワード</div>
<div id="login_pass_input">
<%= f.password_field :password, autocomplete: "current-password", placeholder: "パスワードを入力" %>
</div>

<% if devise_mapping.rememberable? %>
<div class="login_check">
<%= f.check_box :remember_me %>
<%= f.label :remember_me, "ログイン状態を保持する" %>
</div>
<% end %>

<div>
<%= f.submit "ログイン", class:"btn_a" %>
</div>

<% end %>

<%= render "devise/shared/links" %>
</div><!-- wrapper -->
</div><!-- all_wrap -->